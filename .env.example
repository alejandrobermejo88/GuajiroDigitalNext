# ============================================================
# Guajiro Digital — Variables de entorno
# Copia este archivo a .env.local y rellena los valores reales.
# .env.local está en .gitignore → nunca se sube al repositorio.
# ============================================================

# ── NewsAPI ──────────────────────────────────────────────────
# Clave gratuita (100 req/día): https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── Supabase ─────────────────────────────────────────────────
# Supabase Dashboard → Settings → API

# URL del proyecto (pública, empieza por https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon key (pública, usada solo para INSERT de denuncias desde el formulario)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key (PRIVADA, nunca la expongas al browser)
# Usada solo en el servidor para leer todas las denuncias en el panel admin.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Panel de administración ───────────────────────────────────
# Contraseña para entrar en /admin/denuncias
# Elige una contraseña fuerte y guárdala bien.
ADMIN_PASSWORD=elige-una-contrasena-muy-segura

# Secreto para firmar las cookies de sesión (mínimo 32 caracteres)
# Genera uno con: openssl rand -base64 32
ADMIN_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
